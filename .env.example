# ACTmapi ArcGIS FeatureServer URLs (server-side only)
ACTMAPI_BLOCK_URL=https://services1.arcgis.com/E5n4f1VY84i0xSjy/ArcGIS/rest/services/ACTGOV_BLOCKS/FeatureServer/0
ACTMAPI_DIVISION_URL=
ACTMAPI_ADDRESSES_URL=

# National parcel provider URLs (server-side only)
# Leave empty to use defaults where available.
# NSW Cadastre (SIX Maps) — public, no auth required
NSW_CADASTRE_URL=
# TAS theLIST (DPIPWE) — public, no auth required
TAS_CADASTRE_URL=
# VIC Data.Vic / Vicmap Property — requires auth
VIC_CADASTRE_URL=
# QLD QSpatial / DNRME — intermittently available
QLD_CADASTRE_URL=
# SA Location SA — may require auth
SA_CADASTRE_URL=
# WA SLIP — requires free-tier account
WA_CADASTRE_URL=
# NT Geoserver — intermittently available
NT_CADASTRE_URL=

# Default jurisdiction when not inferred from coordinates or text
DEFAULT_JURISDICTION=ACT

# Map tile URLs (client-side, NEXT_PUBLIC_ prefix required)
# Leave empty to use defaults: OpenStreetMap for map, Esri World Imagery for satellite
# Both defaults are free, no token/card required.
#
# maxNativeZoom for defaults:
#   OpenStreetMap: 19
#   CartoDB: 18
#   Esri World Imagery: 19
# Leaflet will scale the highest native tile if zoom exceeds maxNativeZoom,
# so the map never goes blank at close zoom.
NEXT_PUBLIC_MAP_TILE_URL=
NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=
NEXT_PUBLIC_SATELLITE_TILE_URL=
NEXT_PUBLIC_SATELLITE_TILE_ATTRIBUTION=

# Optional browser-readable house design catalogue JSON.
# Leave empty to use the bundled local demo catalogue.
# If set but fetch fails or returns invalid data, falls back to local demo.
NEXT_PUBLIC_DESIGN_CATALOGUE_URL=

# ─── Demo Access Gate ───────────────────────────────────────
# Enable the Lumox client preview access gate.
# Set to "false" to bypass for local/internal testing.
NEXT_PUBLIC_DEMO_ACCESS_ENABLED=true

# SHA-256 hash of the demo password (server-side only).
# Generate with: echo -n 'your-password' | shasum -a 256
# Do NOT commit the real password. Use the hash in production.
DEMO_ACCESS_PASSWORD_HASH=

# Label identifying this demo/password (shown in UI, not secret).
NEXT_PUBLIC_DEMO_ACCESS_PASSWORD_LABEL=brickbrick-demo-001

# Client name displayed in the access gate UI.
NEXT_PUBLIC_DEMO_ACCESS_CLIENT_NAME=BrickBrick

# Terms version identifier, updated when terms change.
NEXT_PUBLIC_DEMO_ACCESS_TERMS_VERSION=2026-05-15-v1

# Dev-only fallback password (NEVER use in production).
# Only read when NODE_ENV !== "production".
DEMO_ACCESS_DEV_PASSWORD=preview123
